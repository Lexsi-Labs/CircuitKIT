# Vendored upstream repos (cloned in place; not part of this repo's tree)
src/LLM-Pruner/
src/LLM-Pruner

# Built docs output (regenerated by mkdocs build)
site/
# Validation suite outputs (regenerated by _runner.py)
examples/validation/results/
examples/validation/_cache/
# Case-study run outputs (regenerated by the case-study scripts)
examples/case-studies/results/
# Circuit visualization galleries (regenerated by visualizations/)
circuit_gallery/
examples/validation/circuit_gallery/

# Scratch outputs from local runs
/artifacts/
/circuits/
/profiler_output/
/circuit_discovery_results*.json
/circuit_discovery_results*.pt
/_verify/
# Regenerated example/notebook outputs (visualizations, galleries, run dirs)
examples/**/*_output/
examples/**/output/
# Experiment run output — regenerated by run_grid.py; not source.
experiments/results/
experiments/checkpoints/
experiments/cache/
experiments/logs/

# LoRA recovery / cross-swap checkpoint directories (regenerable; massive)
experiments/_lora_recovery/*_merged/
experiments/_lora_recovery/*_pruned_only/
experiments/_lora_recovery_gemma/*_merged/
experiments/_lora_recovery_gemma/*_pruned_only/
experiments/_cross_swap/_ckpt_*/

# Result archives (stale/buggy data, kept on disk for reference, not in git)
experiments/results_archive/
experiments/cache_archive_root/

# Exported HF checkpoints from examples/pipeline runs (regenerable; multi-GB).
# Not source — must stay out of git so status/commit don't scan gigabytes.
checkpoints/
examples/**/checkpoints/
pipeline_output/
